\citation{loshchilov2019adamw}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Two-stage system overview. \emph  {Stage\nobreakspace  {}1 (visual path, top)}: both the rendered query and the texture gallery item pass through the shared ViT backbone and ContrastiveHead. \emph  {Stage\nobreakspace  {}2 (multimodal path, bottom)}: the query image and its text description are fused by the LoRA-adapted LLM; the final hidden state feeds a RetrievalHead that maps into the same 256-dim embedding space as Stage\nobreakspace  {}1, enabling image-only and image+text queries against the same gallery index.\relax }}{4}{figure.caption.10}\protected@file@percent }
\newlabel{fig:arch}{{1}{4}{Two-stage system overview. \emph {Stage~1 (visual path, top)}: both the rendered query and the texture gallery item pass through the shared ViT backbone and ContrastiveHead. \emph {Stage~2 (multimodal path, bottom)}: the query image and its text description are fused by the LoRA-adapted LLM; the final hidden state feeds a RetrievalHead that maps into the same 256-dim embedding space as Stage~1, enabling image-only and image+text queries against the same gallery index.\relax }{figure.caption.10}{}}
